#!/bin/sh
# 自动将最新提交信息追加到 CHANGELOG.md 的 [Unreleased] 部分
# 避免递归触发：若已设置 SKIP_CHANGELOG_UPDATE 则直接退出

if [ "$SKIP_CHANGELOG_UPDATE" = "1" ]; then
    exit 0
fi

COMMIT_MSG=$(git log -1 --pretty=%s)
COMMIT_HASH=$(git log -1 --pretty=%h)
DATE_STR=$(date +%Y-%m-%d)

# 更新 CHANGELOG.md：在 [Unreleased] 行后追加记录
TMP_FILE=$(mktemp)
awk -v date="$DATE_STR" -v msg="$COMMIT_MSG" -v hash="$COMMIT_HASH" '
BEGIN { found=0 }
/^## \[Unreleased\]/ {
    print
    print ""
    print "- " date " — " msg " (" hash ")"
    found=1
    next
}
{ print }
' CHANGELOG.md > "$TMP_FILE"
mv "$TMP_FILE" CHANGELOG.md

# 更新 README.md 的最后更新时间戳
TMP_FILE=$(mktemp)
awk -v date="$DATE_STR" '
/最后更新：/ { sub(/最后更新：[0-9]{4}-[0-9]{2}-[0-9]{2}/, "最后更新：" date) }
{ print }
' README.md > "$TMP_FILE"
mv "$TMP_FILE" README.md

git add CHANGELOG.md README.md

# 使用 amend 将更新合并到当前提交，并通过环境变量防止递归
export SKIP_CHANGELOG_UPDATE=1
git commit --amend --no-edit
